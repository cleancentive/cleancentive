# API — relative URL so the frontend hits whichever origin it's served from.
# In dev that's https://cleancentive.local (Caddy → Vite → backend); in prod
# that's https://cleancentive.org.
VITE_API_URL=/api/v1
VITE_LOCATION_GOOD_THRESHOLD_METERS=50
VITE_LOCATION_WARN_THRESHOLD_METERS=500
VITE_DISABLE_LOCATION_ACCURACY_CHECK=false

# Maps — basemap options live in src/config/basemaps.ts.
# The optional STADIA_API_KEY (steward-only experimental layers) is injected
# at container start by docker-entrypoint.sh; it lives in cleancentive-private/.env.

# Analytics (Umami) — leave empty to disable tracking
VITE_UMAMI_SCRIPT_URL=https://analytics.cleancentive.local/script.js
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SHARE_URL=

# Outline wiki — used to build per-team wiki links from collection IDs
VITE_WIKI_URL=https://wiki.cleancentive.local
