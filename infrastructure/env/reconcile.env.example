# Host-level reconcile configuration loaded by systemd.

DEPLOY_ROOT=/opt/cleancentive
PUBLIC_REPO_RAW_BASE=https://raw.githubusercontent.com/cleancentive/cleancentive/main
PRIVATE_ENV_URL=https://raw.githubusercontent.com/cleancentive/cleancentive-private/main/.env
PRIVATE_ENV_TOKEN=replace-with-github-token-or-fine-grained-pat
