#!/usr/bin/env bash
set -euo pipefail

MODE="apply"
MAIN_REPO="cleancentive/cleancentive"
PRIVATE_REPO="cleancentive/cleancentive-private"
DEPLOY_KEY_FILE="${HOME}/.ssh/cleancentive_deploy"
PROD_HOST="46.225.228.123"
PROD_USER="deploy"
TOKEN=""
TOKEN_SOURCE=""
CONFIG_DIR="${HOME}/.config/cleancentive"
CONFIG_FILE="${CONFIG_DIR}/secretato.env"
GAP_COUNT=0

usage() {
  cat <<'EOF'
Usage:
  infrastructure/scripts/secretato [--spy] [--main-repo <owner/repo>] [--private-repo <owner/repo>] [--deploy-key <path>] [--host <value>] [--user <value>]

Modes:
  default   Sync managed GitHub Actions secrets
  --spy     Read-only gap analysis

Requires:
  - gh CLI (install: brew install gh)
  - gh auth login
  - managed deploy key at ~/.ssh/cleancentive_deploy

Token resolution order for PRIVATE_REPO_READ_TOKEN:
  1) PRIVATE_REPO_READ_TOKEN_VALUE env var
  2) ~/.config/cleancentive/secretato.env
  3) gh auth token
EOF
}

print_noarg_status() {
  usage
  if command -v gh >/dev/null 2>&1; then
    echo "Status: gh cli available"
  else
    echo "Status: missing gh cli"
  fi

  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    echo "Status: gh auth configured"
  else
    echo "Status: gh auth missing (run: gh auth login)"
  fi

  if [[ -f "$DEPLOY_KEY_FILE" ]]; then
    echo "Status: deploy key found at $DEPLOY_KEY_FILE"
  else
    echo "Status: missing deploy key at $DEPLOY_KEY_FILE"
  fi
}

ok() {
  echo "OK $1"
}

gap() {
  GAP_COUNT=$((GAP_COUNT + 1))
  echo "$1 $2"
}

synced() {
  echo "SYNCED $1 -> $2"
}

parse_args() {
  MODE="apply"
  MAIN_REPO="cleancentive/cleancentive"
  PRIVATE_REPO="cleancentive/cleancentive-private"
  DEPLOY_KEY_FILE="${HOME}/.ssh/cleancentive_deploy"
  PROD_HOST="46.225.228.123"
  PROD_USER="deploy"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --spy)
        MODE="spy"
        shift
        ;;
      --main-repo)
        MAIN_REPO="$2"
        shift 2
        ;;
      --private-repo)
        PRIVATE_REPO="$2"
        shift 2
        ;;
      --deploy-key)
        DEPLOY_KEY_FILE="$2"
        shift 2
        ;;
      --host)
        PROD_HOST="$2"
        shift 2
        ;;
      --user)
        PROD_USER="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --*)
        echo "Unknown option: $1" >&2
        return 1
        ;;
      *)
        echo "Unexpected argument: $1" >&2
        return 1
        ;;
    esac
  done
}

read_token_from_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    return 1
  fi

  local line
  line="$(grep -E '^PRIVATE_REPO_READ_TOKEN_VALUE=' "$CONFIG_FILE" | tail -n1 || true)"
  if [[ -z "$line" ]]; then
    return 1
  fi

  TOKEN="${line#PRIVATE_REPO_READ_TOKEN_VALUE=}"
  TOKEN="${TOKEN%\"}"
  TOKEN="${TOKEN#\"}"
  [[ -n "$TOKEN" ]]
}

resolve_private_repo_token() {
  TOKEN=""
  TOKEN_SOURCE=""

  if [[ -n "${PRIVATE_REPO_READ_TOKEN_VALUE:-}" ]]; then
    TOKEN="${PRIVATE_REPO_READ_TOKEN_VALUE}"
    TOKEN_SOURCE="env"
    return 0
  fi

  if read_token_from_config; then
    TOKEN_SOURCE="config"
    return 0
  fi

  if command -v gh >/dev/null 2>&1; then
    local gh_token
    gh_token="$(gh auth token 2>/dev/null || true)"
    if [[ -n "$gh_token" ]]; then
      TOKEN="$gh_token"
      TOKEN_SOURCE="gh-auth"
      return 0
    fi
  fi

  return 1
}

check_dependencies() {
  if command -v gh >/dev/null 2>&1; then
    ok "gh cli available"
  else
    gap "MISSING" "gh cli (install: brew install gh)"
    return
  fi

  if gh auth status >/dev/null 2>&1; then
    ok "gh auth configured"
  else
    gap "MISSING" "gh auth (run: gh auth login)"
  fi

  if [[ -f "$DEPLOY_KEY_FILE" ]]; then
    ok "managed deploy private key exists at $DEPLOY_KEY_FILE"
  else
    gap "MISSING" "managed deploy private key at $DEPLOY_KEY_FILE"
  fi

  if resolve_private_repo_token; then
    ok "private repo token source resolved via $TOKEN_SOURCE"
  else
    gap "MISSING" "PRIVATE_REPO_READ_TOKEN source (env, config file, or gh auth token)"
  fi
}

check_repo_access() {
  local repo="$1"
  if gh repo view "$repo" >/dev/null 2>&1; then
    ok "repo access verified for $repo"
  else
    gap "INVALID" "cannot access repo $repo"
  fi
}

secret_exists() {
  local repo="$1"
  local name="$2"
  gh secret list --repo "$repo" --json name --jq '.[].name' 2>/dev/null | grep -Fxq "$name"
}

spy_secret_presence() {
  local repo="$1"
  shift
  local names=("$@")
  local name
  for name in "${names[@]}"; do
    if secret_exists "$repo" "$name"; then
      ok "secret $name exists in $repo"
    else
      gap "MISSING" "secret $name in $repo"
    fi
  done
}

sync_secret() {
  local repo="$1"
  local name="$2"
  local value="$3"
  gh secret set "$name" --repo "$repo" --body "$value" >/dev/null
  synced "$name" "$repo"
}

ensure_config_template() {
  install -d -m 700 "$CONFIG_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<'EOF'
# Optional local override for secretato.
# If set, this value is used before falling back to `gh auth token`.
# PRIVATE_REPO_READ_TOKEN_VALUE=replace-with-token
EOF
    chmod 600 "$CONFIG_FILE"
    ok "created $CONFIG_FILE template"
  fi
}

run_spy() {
  check_dependencies
  check_repo_access "$MAIN_REPO"
  check_repo_access "$PRIVATE_REPO"

  spy_secret_presence "$MAIN_REPO" PROD_HOST PROD_USER PROD_SSH_PRIVATE_KEY PRIVATE_REPO_READ_TOKEN
  spy_secret_presence "$PRIVATE_REPO" PROD_HOST PROD_USER PROD_SSH_PRIVATE_KEY

  if [[ $GAP_COUNT -gt 0 ]]; then
    echo "SUMMARY $GAP_COUNT gaps found"
    exit 1
  fi
  echo "SUMMARY secretato ready"
}

run_apply() {
  check_dependencies
  check_repo_access "$MAIN_REPO"
  check_repo_access "$PRIVATE_REPO"

  if [[ $GAP_COUNT -gt 0 ]]; then
    echo "SUMMARY $GAP_COUNT prerequisite gaps found"
    exit 1
  fi

  ensure_config_template

  local deploy_key_value
  deploy_key_value="$(cat "$DEPLOY_KEY_FILE")"

  sync_secret "$MAIN_REPO" PROD_HOST "$PROD_HOST"
  sync_secret "$MAIN_REPO" PROD_USER "$PROD_USER"
  sync_secret "$MAIN_REPO" PROD_SSH_PRIVATE_KEY "$deploy_key_value"
  sync_secret "$MAIN_REPO" PRIVATE_REPO_READ_TOKEN "$TOKEN"

  sync_secret "$PRIVATE_REPO" PROD_HOST "$PROD_HOST"
  sync_secret "$PRIVATE_REPO" PROD_USER "$PROD_USER"
  sync_secret "$PRIVATE_REPO" PROD_SSH_PRIVATE_KEY "$deploy_key_value"

  echo "SUMMARY secret sync complete"
}

main() {
  if [[ $# -eq 0 ]]; then
    print_noarg_status
    exit 1
  fi

  parse_args "$@"

  if [[ "$MODE" == "spy" ]]; then
    run_spy
  else
    run_apply
  fi
}

if [[ "${SECRETATO_SOURCE_ONLY:-0}" != "1" ]]; then
  main "$@"
fi
