{$DOMAIN} {
  encode zstd gzip

  @api path /api/*
  handle @api {
    request_body {
      max_size 32MB
    }
    reverse_proxy backend:3000 {
      transport http {
        read_timeout 120s
        write_timeout 120s
        response_header_timeout 60s
      }
    }
  }

  handle {
    reverse_proxy frontend:80
  }
}

analytics.{$DOMAIN} {
  reverse_proxy umami:3000
}

wiki.{$DOMAIN} {
  reverse_proxy outline:3000
}

{$DOMAIN_REDIRECT} {
  redir https://{$DOMAIN}{uri} permanent
}
