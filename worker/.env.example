# Environment
NODE_ENV=development

# Database (same as backend)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cleancentive
DB_PASSWORD=cleancentive_dev_password
DB_DATABASE=cleancentive

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Vision detection API — any OpenAI-compatible provider
# DETECTION_BASE_URL defaults to OpenAI if unset
DETECTION_API_KEY=your-api-key
DETECTION_BASE_URL=https://api.mistral.ai/v1
DETECTION_MODEL=mistral-medium-latest
DETECTION_QUEUE_NAME=litter-detection
DETECTION_MAX_IMAGE_SIZE=1024

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cleancentive-images
S3_REGION=us-east-1
