# Environment
NODE_ENV=development

# Database (same as backend)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cleancentive
DB_PASSWORD=cleancentive_dev_password
DB_DATABASE=cleancentive

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Vision detection API — any OpenAI-compatible provider
# DETECTION_BASE_URL defaults to OpenAI if unset
DETECTION_API_KEY=your-api-key
DETECTION_BASE_URL=https://api.mistral.ai/v1
DETECTION_MODEL=mistral-medium-latest
DETECTION_QUEUE_NAME=litter-detection
DETECTION_MAX_IMAGE_SIZE=1024

# Plant identification (Pl@ntNet primary; Mistral fallback via the DETECTION_* config above)
# PLANT_IDENTIFIER: plantnet (default) | mistral | shadow:plantnet+mistral
PLANTNET_API_KEY=your-api-key
PLANTNET_BASE_URL=https://my-api.plantnet.org/v2
PLANTNET_PROJECT=weurope
# 0.3 keeps the invasive species we care about (knotweed @ 30%, hogweed @ 40%,
# goldenrod @ 38%) while excluding noise. UI renders 0.3–0.6 as "Probably X
# — verify" and ≥0.6 as a confident identification.
PLANTNET_MIN_CONFIDENCE=0.3
PLANT_IDENTIFIER=plantnet

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cleancentive-images
S3_REGION=us-east-1
