# Environment
NODE_ENV=development

# Database (same as backend)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=cleancentive
DATABASE_PASSWORD=cleancentive_dev_password
DATABASE_NAME=cleancentive

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Vision analysis API — any OpenAI-compatible provider
# ANALYSIS_BASE_URL defaults to OpenAI if unset
ANALYSIS_API_KEY=your-api-key
ANALYSIS_BASE_URL=https://api.mistral.ai/v1
ANALYSIS_MODEL=mistral-medium-latest
ANALYSIS_QUEUE_NAME=image-analysis

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cleancentive-images
S3_REGION=us-east-1
