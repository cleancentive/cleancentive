# Environment
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cleancentive
DB_PASSWORD=cleancentive_dev_password
DB_DATABASE=cleancentive

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Email / SMTP
# Development: Mailpit (local SMTP server with web UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@cleancentive.local
# Production: Uncomment and configure for SendGrid, AWS SES, or other SMTP provider
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_SECURE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cleancentive-images
S3_REGION=us-east-1
UPLOAD_MAX_SIZE_BYTES=15728640
LOCATION_MAX_ACCURACY_METERS=5000
LOCATION_DISABLE_ACCURACY_CHECK=false
DETECTION_QUEUE_NAME=litter-detection

# API
API_PORT=3000
API_PREFIX=/api/v1
API_URL=https://cleancentive.local
FRONTEND_URL=https://cleancentive.local

# CORS
CORS_ORIGINS=https://cleancentive.local

# OIDC (Outline wiki SSO)
OIDC_ISSUER_URL=https://cleancentive.local/api/v1/oidc
OIDC_REDIRECT_URIS=https://wiki.cleancentive.local/auth/oidc.callback
# Must match the client secret configured in the OIDC client (e.g. Outline).
OIDC_CLIENT_SECRET=outline-dev-secret

# Admin
# Comma-separated list of emails that are automatically promoted to admin
ADMIN_EMAILS=
